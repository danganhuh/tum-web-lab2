---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const entries = await getCollection("event_announcements");
const sorted = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Anunțuri evenimente · Muzeul de Istorie și Etnografie din Bălți">
  <main class="min-h-screen bg-museum-bg pb-16">
    <div class="border-b border-black/10 bg-museum-sand/80">
      <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
        <h1 class="text-lg font-extrabold text-[#1f1a15]">Anunțuri evenimente</h1>
        <a class="text-sm font-semibold text-[#7b5234] hover:underline" href="/">Acasă</a>
      </div>
    </div>

    <ul class="mx-auto max-w-3xl divide-y divide-black/10 px-4">
      {
        sorted.length === 0 ? (
          <li class="py-10 text-[#5e5650]">Încă nu există anunțuri publicate.</li>
        ) : (
          sorted.map((entry) => {
            const d = entry.data.date.toLocaleDateString("ro-RO", {
              year: "numeric",
              month: "short",
              day: "numeric"
            });
            return (
              <li class="py-6">
                <a class="group block" href={`/event-announcements/${entry.id}`}>
                  <p class="text-xs font-semibold text-[#7b5234]">{d}</p>
                  <h2 class="mt-1 text-base font-extrabold text-[#1f1a15] group-hover:text-[#7b5234]">{entry.data.title}</h2>
                  <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-[#5e5650]">{entry.data.description}</p>
                </a>
              </li>
            );
          })
        )
      }
    </ul>
  </main>
</Layout>
