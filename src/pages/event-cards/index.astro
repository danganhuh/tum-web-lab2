---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const entries = await getCollection("event_cards");
const sorted = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Carduri evenimente · Muzeul de Istorie și Etnografie din Bălți">
  <main class="min-h-screen bg-museum-bg pb-16">
    <div class="border-b border-black/10 bg-museum-sand/80">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <h1 class="text-lg font-extrabold text-[#1f1a15]">Carduri evenimente</h1>
        <a class="text-sm font-semibold text-[#7b5234] hover:underline" href="/">Acasă</a>
      </div>
    </div>

    <ul class="mx-auto grid max-w-6xl gap-6 px-4 py-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        sorted.length === 0 ? (
          <li class="col-span-full py-10 text-center text-[#5e5650]">Încă nu există carduri publicate.</li>
        ) : (
          sorted.map((entry) => {
            const d = entry.data.date.toLocaleDateString("ro-RO", {
              year: "numeric",
              month: "short",
              day: "numeric"
            });
            return (
              <li>
                <a
                  class="flex h-full flex-col overflow-hidden rounded-xl border border-black/10 bg-white shadow-lg shadow-black/10 transition hover:-translate-y-1 hover:shadow-xl"
                  href={`/event-cards/${entry.id}`}
                >
                  <img class="h-44 w-full object-cover" src={entry.data.image} alt="" loading="lazy" decoding="async" />
                  <div class="flex flex-1 flex-col gap-2 p-4">
                    <p class="text-xs font-semibold text-[#7b5234]">{d}</p>
                    <h2 class="text-base font-extrabold leading-snug text-[#1f1a15]">{entry.data.title}</h2>
                    <p class="line-clamp-3 text-sm leading-relaxed text-[#5e5650]">{entry.data.description}</p>
                    <span class="mt-auto text-sm font-semibold text-[#7b5234]">Detalii →</span>
                  </div>
                </a>
              </li>
            );
          })
        )
      }
    </ul>
  </main>
</Layout>
