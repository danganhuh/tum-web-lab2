---
import Layout from "../layouts/Layout.astro";
const withBase = (path) =>
  `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}${path.replace(/^\/+/, "")}`;
---

<Layout>
  <header class="sticky top-0 z-20 w-full border-b border-black/10 bg-museum-sand/95 backdrop-blur" id="top">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:py-4">
      <a class="flex items-center gap-3 text-[1.03rem] font-bold tracking-[0.02em] text-[#1f1a15]" href="#top" aria-label="Muzeul de Istorie și Etnografie din Bălți">
        <img class="h-9 w-auto object-contain mix-blend-multiply" src={withBase("/logo/logo.png")} alt="Logo Muzeul de Istorie și Etnografie din Bălți" decoding="async" fetchpriority="high" />
        <span class="leading-tight">Muzeul de Istorie și Etnografie din Bălți</span>
      </a>
      <nav class="hidden md:block" aria-label="Navigare Principală">
        <ul class="flex gap-4">
          <li><a class="border-b border-transparent text-[#1f1a15]/90 transition hover:border-[#1f1a15]/60 hover:text-black" href="#exponatele">Expoziții</a></li>
          <li><a class="border-b border-transparent text-[#1f1a15]/90 transition hover:border-[#1f1a15]/60 hover:text-black" href="#vizite">Vizite</a></li>
          <li><a class="border-b border-transparent text-[#1f1a15]/90 transition hover:border-[#1f1a15]/60 hover:text-black" href="#despre">Despre noi</a></li>
        </ul>
      </nav>
      <div class="relative md:hidden">
        <details class="group">
          <summary class="cursor-pointer list-none rounded-full border border-[#1f1a15]/20 bg-white px-3 py-2 text-lg font-bold text-[#1f1a15] shadow-sm">
            <span aria-hidden="true">☰</span>
            <span class="sr-only">Deschide navigarea mobil</span>
          </summary>
          <div class="absolute right-0 mt-2 w-48 origin-top-right rounded-xl border border-[#1f1a15]/15 bg-white p-2 shadow-xl opacity-0 scale-95 transition duration-200 group-open:opacity-100 group-open:scale-100">
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-[#1f1a15] hover:bg-museum-cream" href="#exponatele">Expoziții</a>
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-[#1f1a15] hover:bg-museum-cream" href="#despre">Despre noi</a>
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-[#1f1a15] hover:bg-museum-cream" href="#vizite">Rezervă vizita</a>
            <a class="block rounded-lg px-3 py-2 text-sm font-semibold text-[#1f1a15] hover:bg-museum-cream" href="#gasesti">Locație</a>
          </div>
        </details>
      </div>
    </div>
  </header>

  <main>
    <section class="relative flex min-h-[85vh] items-center overflow-hidden sm:min-h-screen">
      <img class="absolute inset-0 h-full w-full object-cover object-center brightness-[0.72] saturate-50 contrast-95 sm:hidden" src={withBase("/images/new_mus.jpg")} alt="Muzeul de Istorie și Etnografie" loading="eager" decoding="async" fetchpriority="high" />
      <video class="hero-pan absolute inset-0 hidden h-full w-full -translate-y-12 scale-110 object-cover object-center brightness-[0.72] saturate-50 contrast-95 sm:block" autoplay muted loop playsinline preload="metadata" poster={withBase("/images/new_mus.jpg")} aria-hidden="true" tabindex="-1">
        <source src={withBase("/video/Video Project.mp4")} type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 to-black/75" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto w-full max-w-4xl px-4 pt-16 pb-10 text-center sm:pt-20 sm:pb-12 sm:text-left">
        <h1 class="font-serif leading-tight">
          <span class="block text-[clamp(2.3rem,5.6vw,4.9rem)] font-bold tracking-tight text-white drop-shadow-[0_14px_28px_rgba(0,0,0,0.24)]">Muzeul de Istorie și Etnografie</span>
        </h1>

        <p class="mt-6 max-w-[58ch] text-base leading-relaxed text-white/80 sm:mt-8 sm:text-lg">Descoperiți povești, artefacte și expoziții interactive care readuc la viață trecutul municipiului Bălți.</p>

        <div class="mt-6 flex flex-wrap justify-center gap-3 sm:justify-start">
          <a class="group inline-flex items-center gap-2 rounded-md border border-white/20 bg-gradient-to-br from-[#9a6a45] to-[#7b5234] px-5 py-3 font-semibold text-white shadow-lg shadow-black/25 transition hover:-translate-y-0.5" href="#exponatele">
            Explorează expozițiile noastre
            <span class="transition-transform group-hover:translate-x-0.5">→</span>
          </a>
          <a class="inline-flex items-center gap-2 rounded-md border border-white/60 px-5 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/10" href="#vizite">Planifică vizita ta</a>
        </div>
      </div>
    </section>

    <section class="bg-museum-sand py-14 sm:py-20" id="exponatele" aria-labelledby="exhibitions-title">
      <div class="mx-auto max-w-6xl px-4">
        <div class="mb-10">
          <h2 class="text-[clamp(1.45rem,2.3vw,2rem)] font-extrabold text-[#1f1a15]" id="exhibitions-title">Expozițiile noastre</h2>
          <p class="mt-4 text-justify leading-relaxed text-[#5e5650]">În fiecare an, Muzeul de Istorie și Etnografie din Bălți organizează expoziții captivante care explorează trecutul și patrimoniul local din nordul țării. Vă îndemnăm să vizitați muzeul pentru a trăi aceste momente istorice într-un cadru interactiv și educațional.</p>
        </div>

        <div class="flex snap-x snap-mandatory gap-3 overflow-x-auto pb-5 pl-4 pr-4 sm:gap-4 sm:px-0">
          <a class="flex w-[min(86vw,320px)] flex-none snap-start flex-col overflow-hidden rounded-xl border border-black/10 bg-white shadow-lg shadow-black/10 transition hover:-translate-y-1 hover:shadow-xl sm:w-[clamp(270px,30vw,360px)]" href="#despre" aria-label="Detalii expoziție: Tradiții și meșteșuguri">
            <img class="h-48 w-full object-cover" src={withBase("/images/expozitii/madona1_expo.jpg")} alt="Expoziție viitoare despre tradiții și meșteșuguri" loading="lazy" decoding="async" />
            <div class="flex flex-1 flex-col gap-2 px-4 py-4">
              <h3 class="text-base font-extrabold leading-snug text-[#1f1a15]">Vernisaj de expoziție: Madona din Ordășei</h3>
              <p class="text-sm leading-relaxed text-[#5e5650]">O incursiune în descoperirile arheologice ale tumulului 20 de la Ordășei</p>
              <span class="mt-auto text-sm font-semibold text-[#7b5234]">Vezi mai mult →</span>
            </div>
          </a>

          <a class="flex w-[min(86vw,320px)] flex-none snap-start flex-col overflow-hidden rounded-xl border border-black/10 bg-white shadow-lg shadow-black/10 transition hover:-translate-y-1 hover:shadow-xl sm:w-[clamp(270px,30vw,360px)]" href="#vizite" aria-label="Detalii expoziție: Deportarile sovietice din 1940">
            <img class="h-48 w-full object-cover" src={withBase("/images/expozitii/exhib.jpg")} alt="Expoziție temporară de patrimoniu local" loading="lazy" decoding="async" />
            <div class="flex flex-1 flex-col gap-2 px-4 py-4">
              <h3 class="text-base font-extrabold leading-snug text-[#1f1a15]">Colecții și memorii ale victimelor deportărilor anului 1940</h3>
              <p class="text-sm leading-relaxed text-[#5e5650]">Colecții de obiecte și mărturii ale victimelor deportărilor sovietice.</p>
              <span class="mt-auto text-sm font-semibold text-[#7b5234]">Vezi mai mult →</span>
            </div>
          </a>

          <a class="flex w-[min(86vw,320px)] flex-none snap-start flex-col overflow-hidden rounded-xl border border-black/10 bg-white shadow-lg shadow-black/10 transition hover:-translate-y-1 hover:shadow-xl sm:w-[clamp(270px,30vw,360px)]" href="#vizite" aria-label="Detalii expoziție: Istoria urbană a Bălțiului">
            <img class="h-48 w-full object-cover" src={withBase("/images/expozitii/urbanism_expo.jpg")} alt="Expoziție despre istoria urbană a municipiului Bălți" loading="lazy" decoding="async" />
            <div class="flex flex-1 flex-col gap-2 px-4 py-4">
              <h3 class="text-base font-extrabold leading-snug text-[#1f1a15]">Urbanism și planificare - 180 ani de la primul plan arhitectural al orașului.</h3>
              <p class="text-sm leading-relaxed text-[#5e5650]">Descoperiți evoluția planurilor de urbanism și planificare în Bălți.</p>
              <span class="mt-auto text-sm font-semibold text-[#7b5234]">Vezi mai mult →</span>
            </div>
          </a>

          <a class="flex w-[min(86vw,320px)] flex-none snap-start flex-col overflow-hidden rounded-xl border border-black/10 bg-white shadow-lg shadow-black/10 transition hover:-translate-y-1 hover:shadow-xl sm:w-[clamp(270px,30vw,360px)]" href="#despre" aria-label="Detalii expoziție: Epoca modernă">
            <img class="h-48 w-full object-cover" src={withBase("/images/expozitii/epoca_moderna_expo.jpg")} alt="Expoziție foto de patrimoniu și etnografie" loading="lazy" decoding="async" />
            <div class="flex flex-1 flex-col gap-2 px-4 py-4">
              <h3 class="text-base font-extrabold leading-snug text-[#1f1a15]">Descoperiți Bălțiul de seară din epoca modernă</h3>
              <p class="text-sm leading-relaxed text-[#5e5650]">Expoziție cu fotografii și obiecte care reflectă viața de seară în Bălțiul modern.</p>
              <span class="mt-auto text-sm font-semibold text-[#7b5234]">Vezi mai mult →</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="bg-museum-cream py-14 sm:py-20" id="despre" aria-labelledby="mission-title">
      <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,1fr)]">
        <div class="group relative min-h-[320px] overflow-hidden rounded-xl border border-black/10 bg-museum-accent2 shadow-lg shadow-black/10 transition hover:-translate-y-1 hover:shadow-xl" aria-hidden="true">
          <div class="absolute inset-0">
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/excursie.jpg")} alt="" loading="eager" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/excursie2.jpg")} alt="" loading="lazy" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/excursie3.jpg")} alt="" loading="lazy" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/excursie_1.jpg")} alt="" loading="lazy" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/exponate.jpg")} alt="" loading="lazy" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/masurare.jpg")} alt="" loading="lazy" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/proiect.jpg")} alt="" loading="lazy" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/rezultate.jpg")} alt="" loading="lazy" decoding="async" />
            <img class="mission-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-transform duration-500 group-hover:scale-105" src={withBase("/images/muzeografi/semnare.jpg")} alt="" loading="lazy" decoding="async" />
          </div>
        </div>

        <div class="max-w-[62ch]">
          <h2 class="text-[clamp(1.45rem,2.3vw,2rem)] font-extrabold text-[#1f1a15]" id="mission-title">Despre muzeu și misiunea noastră</h2>
          <p class="mt-5 leading-relaxed text-[#5e5650]">Muzeul de Istorie și Etnografie din Bălți are misiunea de a conserva, cerceta și valorifica patrimoniul cultural al regiunii de nord, în special a municipiului Bălți. Prin expoziții, activități educaționale și proiecte comunitare, conectăm trecutul cu prezentul într-un mod accesibil tuturor generațiilor.</p>
          <p class="mt-5 leading-relaxed text-[#5e5650]">În ultimii ani, muzeul s-a implicat în proiecte moderne, precum digitalizarea patrimoniului și expoziții internaționale, inclusiv colaborări cu specialiști din Republica Cehă pentru prezentarea descoperirilor arheologice rare.</p>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-museum-sand py-14 sm:py-16" id="vizite" aria-labelledby="visits-title">
      <figure class="exponat-reveal group absolute bottom-4 left-[max(0.9rem,calc((100vw-1100px)/2+1rem))] z-10 hidden max-w-[220px] opacity-0 lg:block" style="animation-delay: 0.9s;">
        <img class="block w-full animate-[coinTilt_26s_ease-in-out_infinite]" src={withBase("/images/exponate/moneda_anim.png")} alt="Monedă istorică din colecția muzeului" loading="lazy" decoding="async" />
        <figcaption class="pointer-events-none absolute left-[calc(100%+0.55rem)] top-1/2 w-[230px] -translate-x-1 -translate-y-1/2 rounded-lg bg-[#1f1a15] px-2.5 py-2 text-xs leading-relaxed text-white opacity-0 transition group-hover:translate-x-0 group-hover:opacity-100">Monedă istorică: descoperită în nordul Moldovei, sec. XIX.</figcaption>
      </figure>
      <figure class="exponat-reveal group absolute top-52 left-[calc(max(0.9rem,calc((100vw-1100px)/2+1rem))+7rem)] z-10 hidden max-w-[240px] opacity-0 lg:block" style="animation-delay: 1.35s;">
        <img class="block w-full animate-[earringTilt_18s_ease-in-out_infinite]" src={withBase("/images/exponate/cercei_anim.png")} alt="Pereche de cercei de epocă" loading="lazy" decoding="async" />
        <figcaption class="pointer-events-none absolute left-[calc(100%+0.55rem)] top-1/2 w-[230px] -translate-x-1 -translate-y-1/2 rounded-lg bg-[#1f1a15] px-2.5 py-2 text-xs leading-relaxed text-white opacity-0 transition group-hover:translate-x-0 group-hover:opacity-100">Cercei de epocă: piesă decorativă restaurată din colecția etnografică.</figcaption>
      </figure>
      <div class="mx-auto grid max-w-6xl items-start gap-8 px-4 lg:grid-cols-2">
        <div class="max-w-[62ch]">
          <h2 class="text-[clamp(1.35rem,2.1vw,1.85rem)] font-extrabold text-[#1f1a15]" id="visits-title">Planifică vizita ta</h2>
          <p class="mt-3 hidden leading-relaxed text-[#5e5650] md:block">Completează formularul de alături, iar echipa muzeului te va contacta pentru confirmarea detaliilor vizitei.</p>
        </div>

        <section class="grid gap-3 rounded-xl border border-black/10 bg-white p-4 shadow-lg shadow-black/10 md:hidden" aria-labelledby="mobile-spotlight-title">
          <p class="text-base leading-relaxed text-[#5e5650]">Cu ajutorul telefonului mobil, poți ajunge rapid la secțiunile importante și poți rezerva vizita dintr-un singur tap.</p>
          <img class="h-[170px] w-full rounded-lg border border-black/10 object-cover" src={withBase("/images/muzeografi/excursie_1.jpg")} alt="Vizitatori în muzeu" loading="lazy" decoding="async" />
        </section>

        <form class="grid gap-4 rounded-xl border border-black/10 bg-white p-4 shadow-lg shadow-black/10 lg:grid-cols-2 lg:self-start" id="visit-form" action="" method="post">
          <div class="flex flex-col gap-1.5 lg:col-span-2">
            <label class="text-sm font-bold text-[#1f1a15]" for="visitor-name">Nume și prenume vizitator/organizator</label>
            <input class="w-full rounded-lg border border-black/20 px-3 py-2 text-[#1f1a15] focus:border-black/40 focus:outline-none focus:ring-4 focus:ring-black/10" id="visitor-name" name="visitor-name" type="text" required />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-bold text-[#1f1a15]" for="visitor-email">Email</label>
            <input class="w-full rounded-lg border border-black/20 px-3 py-2 text-[#1f1a15] focus:border-black/40 focus:outline-none focus:ring-4 focus:ring-black/10" id="visitor-email" name="visitor-email" type="email" required />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-bold text-[#1f1a15]" for="visitor-phone">Telefon</label>
            <input class="w-full rounded-lg border border-black/20 px-3 py-2 text-[#1f1a15] focus:border-black/40 focus:outline-none focus:ring-4 focus:ring-black/10" id="visitor-phone" name="visitor-phone" type="tel" required />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-bold text-[#1f1a15]" for="visit-date">Data dorită</label>
            <input class="w-full rounded-lg border border-black/20 px-3 py-2 text-[#1f1a15] focus:border-black/40 focus:outline-none focus:ring-4 focus:ring-black/10" id="visit-date" name="visit-date" type="date" required />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-bold text-[#1f1a15]" for="group-size">Număr de vizitatori</label>
            <input class="w-full rounded-lg border border-black/20 px-3 py-2 text-[#1f1a15] focus:border-black/40 focus:outline-none focus:ring-4 focus:ring-black/10" id="group-size" name="group-size" type="number" min="1" required />
          </div>

          <div class="flex flex-col gap-1.5 lg:col-span-2">
            <label class="text-sm font-bold text-[#1f1a15]" for="visit-exhibition">Expoziția dorită</label>
            <select class="w-full rounded-lg border border-black/20 px-3 py-2 text-[#1f1a15] focus:border-black/40 focus:outline-none focus:ring-4 focus:ring-black/10" id="visit-exhibition" name="visit-exhibition" required>
              <option value="" selected disabled>Alege o expoziție</option>
              <option value="madona-din-ordasei">Vernisaj de expoziție: Madona din Ordășei</option>
              <option value="deportari-1940">Colecții și memorii ale victimelor deportărilor anului 1940</option>
              <option value="urbanism-180-ani">Urbanism și planificare - 180 ani de la primul plan arhitectural al orașului</option>
              <option value="balti-epoca-moderna">Descoperiți Bălțiul de seară din epoca modernă</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5 lg:col-span-2">
            <label class="text-sm font-bold text-[#1f1a15]" for="visit-message">Mesaj</label>
            <textarea class="w-full rounded-lg border border-black/20 px-3 py-2 text-[#1f1a15] focus:border-black/40 focus:outline-none focus:ring-4 focus:ring-black/10" id="visit-message" name="visit-message" rows="4" placeholder="Menționează expoziția preferată sau alte detalii utile."></textarea>
          </div>

          <button class="inline-flex items-center justify-center rounded-md border border-white/20 bg-gradient-to-br from-[#9a6a45] to-[#7b5234] px-5 py-3 font-semibold text-white shadow-lg shadow-black/25 transition hover:-translate-y-0.5 lg:col-span-2 lg:justify-self-start" type="submit">Trimite</button>
        </form>
      </div>
    </section>

    <section class="bg-museum-cream py-14 sm:py-16" id="gasesti" aria-labelledby="find-us-title">
      <div class="mx-auto max-w-6xl px-4">
        <h2 class="mb-4 text-[clamp(1.35rem,2.1vw,1.85rem)] font-extrabold text-[#1f1a15]" id="find-us-title">Cum să ne găsești?</h2>
        <div class="grid gap-8 lg:grid-cols-2">
          <div class="grid gap-4 lg:grid-rows-2">
            <div class="rounded-xl border border-black/10 bg-white p-4 shadow-lg shadow-black/10">
              <h3 class="mb-3 text-base font-extrabold text-[#1f1a15]">Program de vizitare</h3>
              <ul class="grid gap-2 text-[#5e5650]">
                <li class="flex justify-between gap-4"><span>Marți - Vineri</span><strong class="text-[#1f1a15]">8:00 - 17:00</strong></li>
                <li class="flex justify-between gap-4"><span>Sâmbătă</span><strong class="text-[#1f1a15]">8:00 - 16:00</strong></li>
                <li class="flex justify-between gap-4"><span>Luni - Duminică</span><strong class="text-[#1f1a15]">Închis</strong></li>
              </ul>
            </div>

            <div class="rounded-xl border border-black/10 bg-white p-4 shadow-lg shadow-black/10">
              <h3 class="mb-3 text-base font-extrabold text-[#1f1a15]">Locație</h3>
              <div class="space-y-1 text-[#5e5650]">
                <p>Strada Ștefan cel Mare, 82, Bălți, Republica Moldova</p>
                <p>Acces: intrarea principală este din curte, cu acces facil pentru orice vizitator.</p>
                <p>Transport: troleibusele: 10, 1. autobusul: 101.</p>
                <p>Telefon: +373 231 00 000</p>
              </div>
            </div>
          </div>

          <div class="min-h-[320px] overflow-hidden rounded-xl border border-black/10 bg-white shadow-lg shadow-black/10 lg:min-h-[420px]">
            <iframe
              class="h-full w-full"
              title="Harta Muzeului de Istorie și Etnografie din Bălți"
              src="https://www.google.com/maps?q=Muzeul%20de%20Istorie%20si%20Etnografie%20Balti&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div class="fixed inset-x-0 bottom-0 z-30 border-t border-black/10 bg-museum-sand/95 px-4 py-3 md:hidden" aria-label="Acțiune rapidă mobil">
    <a class="block rounded-md border border-white/20 bg-gradient-to-br from-[#9a6a45] to-[#7b5234] px-5 py-3 text-center font-semibold text-white shadow-lg shadow-black/25" id="mobile-main-cta" href="#visit-form">Rezervă vizita</a>
  </div>

  <footer class="py-8 text-center text-museum-muted">
    <div class="mx-auto max-w-6xl px-4">
      <small>© Muzeul de Istorie și Etnografie din Bălți</small>
